{
  "files.exclude": {
    "miktex": true,
    "python-venv": true,
    "texlive": true
  },
  "files.watcherExclude": {
    "**/miktex/**": true,
    "**/python-venv/**": true,
    "**/texlive/**": true
  },
  "search.exclude": {
    "**/miktex/**": true,
    "**/python-venv/**": true,
    "**/texlive/**": true
  },

  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.env.windows": {
    "PATH": "D:\\Tool\\math\\miktex\\texmfs\\install\\miktex\\bin\\x64;${env:PATH}"
  },

  "python.defaultInterpreterPath": "D:\\Tool\\math\\python-venv\\Scripts\\python.exe",

  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "D:\\Tool\\math\\miktex\\texmfs\\install\\miktex\\bin\\x64\\xelatex.exe",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    { "name": "xelatex x2", "tools": ["xelatex", "xelatex"] }
  ],
  "latex-workshop.latex.recipe.default": "xelatex x2",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "latex-workshop.latex.clean.method": "glob",
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux", "*.bbl", "*.blg", "*.log", "*.out", "*.toc",
    "*.synctex.gz", "*.fls", "*.fdb_latexmk"
  ]
}
